.about.about--active
  .about__wrapper
    .about__story
      h4.about__story__title(data-animation=assets.about.story.body.animation)!=assets.about.story.body.text
      button.about__story__cta!=assets.about.story.button.text

    .about__certDist
      .about__certDist__content
        h5.certDist__content__text(data-animation=assets.about.certDist.body.animation)!=assets.about.certDist.body.text
        h2.certDist__content__title(data-animation=assets.about.certDist.title.animation)!=assets.about.certDist.title.text
      figure.about__certDist__media
        img.about__certDist__media__image(alt=assets.about.certDist.image.alt src=assets.about.certDist.image.url)

    include ../../_includes/partials/contact.pug
    include ../../_includes/partials/footer.pug
